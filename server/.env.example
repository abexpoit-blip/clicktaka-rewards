# VPS-এ server/.env নামে এই ফাইলটি কপি করে value বসান
DB_HOST=localhost
DB_PORT=3306
DB_USER=clicktaka
DB_PASS=change_this_strong_password
DB_NAME=clicktaka

# 64+ char random string. Generate: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret_64_chars_minimum

PORT=3001
NODE_ENV=production

# Frontend origin (CORS)
FRONTEND_URL=https://clicktaka24.com

# Cookie domain (.clicktaka24.com so it works on subdomains too)
COOKIE_DOMAIN=.clicktaka24.com

# Admin panel login (username + password — no phone needed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Clicktaka247
